          },
          {
            "item": "black pepper",
            "quantity": "1/2 teaspoon",
            "section": "Spices & Seasonings"
          },
          {
            "item": "cauliflower (leaves removed, bottom stem trimmed and cut into 1/2-inch-thick slices and broken into small to medium pieces)",
            "quantity": "1 head",
