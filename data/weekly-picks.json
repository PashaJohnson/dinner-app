        "title": "Elote Chicken Pasta Salad",
        "sourceUrl": "https://moribyan.com/elote-chicken-pasta-salad/?utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAdGRleASuSKpleHRuA2FlbQIxMQBzcnRjBmFwcF9pZA8xMjQwMjQ1NzQyODc0MTQAAafgZnY3XIv7-IR28hpbz28oeqlJUy8-jsQ8t5vPyPZYoOWtsaN8g4Fx3ufPjA_aem_ufVMt6JPI78hn0DsLy2atw#recipe-card",
        "ingredients": [
          {
            "item": "chicken breast",
            "quantity": "1 pound",
            "section": "Meat & Seafood"
          },
          {
            "item": "olive oil",
            "quantity": "1 tablespoon, plus additional for pan",
            "section": "Pantry"
          },
          {
            "item": "salt",
            "quantity": "1 teaspoon",
            "section": "Spices & Seasonings"
          },
          {
            "item": "paprika",
            "quantity": "½ teaspoon",
            "section": "Spices & Seasonings"
          },
          {
