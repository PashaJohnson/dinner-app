            "quantity": "1/8 tsp",
            "section": "Spices & Seasonings"
          },
          {
            "item": "Parmesan-Reggiano or Romano cheese freshly grated",
            "quantity": "3/4 cup",
            "section": "Dairy & Eggs"
          },
          {
            "item": "basil leaves (packed)",
            "quantity": "3 cups",
            "section": "Produce"
          },
          {
            "item": "extra virgin olive oil",
            "quantity": "1 cup",
